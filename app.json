{
  "expo": {
    "name": "AC Companion",
    "slug": "animalcrossing-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "accompanion",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beajenkinson.accompanion"
    },
    "android": {
      "package": "com.beajenkinson.accompanion"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
